# Pacman
alias pacin='sudo pacman -S'
alias pacrem='sudo pacman -Rns'
alias pacupd='sudo pacman -Syu'
alias pacclean='sudo pacman -Rns $(pacman -Qdtq)'

# Hyprland
alias hconf='hyprctl reload'
alias hwin='hyprctl clients'
alias hwork='hyprctl workspaces'
alias hinfo='hyprctl activewindow'
alias hmon='hyprctl monitors'
alias econf='$EDITOR ~/.config/hypr/hyprland.conf'
